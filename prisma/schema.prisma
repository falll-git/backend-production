model debtor_contracts {
  id                  String    @id @default(uuid())
  no_kontrak          String    @unique
  debtor_id           String
  product_id          String
  akad_type_id        String
  branch_id           String?
  marketing_user_id   String?
  tanggal_akad        DateTime
  tanggal_jatuh_tempo DateTime?
  plafond             Decimal   @default(0) @db.Decimal(18, 2)
  pokok               Decimal   @default(0) @db.Decimal(18, 2)
  margin              Decimal   @default(0) @db.Decimal(18, 2)
  tenor               Int
  outstanding_pokok   Decimal   @default(0) @db.Decimal(18, 2)
  outstanding_margin  Decimal   @default(0) @db.Decimal(18, 2)
  status              String    @default("ACTIVE")
  objek_pembiayaan    String?
  agunan              String?
  created_by          String?
  updated_by          String?
  deleted_by          String?
  deleted_at          DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  debtor              digital_debtors               @relation(fields: [debtor_id], references: [id])
  product             financing_products            @relation(fields: [product_id], references: [id])
  akad_type           contract_types                @relation(fields: [akad_type_id], references: [id])
  branch              branches?                     @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  marketing_user      users?                        @relation("ContractMarketingOwner", fields: [marketing_user_id], references: [id], onDelete: SetNull)
  collectibilities    debtor_collectibilities[]
  collaterals          debtor_collaterals[]
  slik_snapshots       debtor_contract_slik_snapshots[]
  documents           debtor_documents[]
  import_records      debtor_external_records[]
  slik_records        debtor_slik_records[]
  marketing_items     debtor_marketing_activities[]
  marketing_timelines debtor_marketing_timelines[]
  warning_letters     debtor_warning_letters[]
  legal_prints        legal_print_histories[]
  ideb_uploads        debtor_ideb_uploads[]
  notary_progress     legal_notary_progress[]
  insurance_progress  legal_insurance_progress[]
  kjpp_progress       legal_kjpp_progress[]
  claims              legal_claims[]
  deposits            legal_deposits[]

  @@index([debtor_id])
  @@index([product_id])
  @@index([akad_type_id])
  @@index([branch_id])
  @@index([marketing_user_id])
  @@index([status])
  @@index([deleted_at])
}

