generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model users {
  id                              String                   @id @default(uuid())
  name                            String
  username                        String                   @unique
  email                           String                   @unique
  phone                           String?
  is_active                       Boolean                  @default(true)
  can_access_restricted_documents Boolean                  @default(false)
  onboarding_status               user_onboarding_statuses @default(NOT_ACTIVATED)
  password                        String
  role_id                         String
  division_id                     String
  email_verified_at               DateTime?
  password_set_at                 DateTime?
  invited_at                      DateTime?
  activated_at                    DateTime?
  deactivated_at                  DateTime?
  deactivated_by                  String?
  deactivation_reason             String?
  reactivated_at                  DateTime?
  reactivated_by                  String?
  reactivation_reason             String?

  role               roles                @relation(fields: [role_id], references: [id])
  division           divisions            @relation(fields: [division_id], references: [id])
  auth_action_tokens auth_action_tokens[]
  refresh_tokens     refresh_tokens[]
  deactivator        users?               @relation("UsersDeactivator", fields: [deactivated_by], references: [id], onDelete: SetNull)
  reactivator        users?               @relation("UsersReactivator", fields: [reactivated_by], references: [id], onDelete: SetNull)
  deactivated_users  users[]              @relation("UsersDeactivator")
  reactivated_users  users[]              @relation("UsersReactivator")

  sent_dispositions     incoming_mail_dispositions[] @relation("SenderDisposition")
  received_dispositions incoming_mail_dispositions[] @relation("ReceiverDisposition")

  sent_memo_dispositions     memorandum_dispositions[] @relation("SenderMemoDisposition")
  received_memo_dispositions memorandum_dispositions[] @relation("ReceiverMemoDisposition")

  created_incoming_mails        incoming_mails[]                 @relation("IncomingMailsCreator")
  updated_incoming_mails        incoming_mails[]                 @relation("IncomingMailsUpdater")
  deleted_incoming_mails        incoming_mails[]                 @relation("IncomingMailsDeleter")
  managed_incoming_mail_targets incoming_mail_target_divisions[] @relation("IncomingMailTargetManager")

  created_digital_documents           digital_documents[]                @relation("DigitalDocumentsCreator")
  owned_digital_documents             digital_documents[]                @relation("DigitalDocumentsOwner")
  updated_digital_documents           digital_documents[]                @relation("DigitalDocumentsUpdater")
  deleted_digital_documents           digital_documents[]                @relation("DigitalDocumentsDeleter")
  related_digital_documents           digital_document_related_users[]
  uploaded_document_files             document_files[]                   @relation("DocumentFileUploader")
  requested_digital_document_accesses digital_document_access_requests[] @relation("DigitalDocumentAccessRequester")
  owned_digital_document_accesses     digital_document_access_requests[] @relation("DigitalDocumentAccessOwner")
  acted_digital_document_accesses     digital_document_access_requests[] @relation("DigitalDocumentAccessActor")
  borrowed_digital_document_loans     digital_document_loans[]           @relation("DigitalDocumentLoanBorrower")
  approved_digital_document_loans     digital_document_loans[]           @relation("DigitalDocumentLoanApprover")
  rejected_digital_document_loans     digital_document_loans[]           @relation("DigitalDocumentLoanRejector")
  handed_over_digital_document_loans  digital_document_loans[]           @relation("DigitalDocumentLoanHandOverActor")
  returned_digital_document_loans     digital_document_loans[]           @relation("DigitalDocumentLoanReturnActor")
  digital_document_activity_logs      digital_document_activity_logs[]   @relation("DigitalDocumentActivityActor")
  received_notifications              notifications[]                    @relation("NotificationRecipient")
  created_notifications               notifications[]                    @relation("NotificationCreator")
  marketing_debtors                   digital_debtors[]                  @relation("DebtorMarketingOwner")
  marketing_contracts                 debtor_contracts[]                 @relation("ContractMarketingOwner")

  created_outgoing_mails outgoing_mails[] @relation("OutgoingMailsCreator")
  updated_outgoing_mails outgoing_mails[] @relation("OutgoingMailsUpdater")
  deleted_outgoing_mails outgoing_mails[] @relation("OutgoingMailsDeleter")

  created_memorandums        memorandums[]                 @relation("MemorandumCreator")
  updated_memorandums        memorandums[]                 @relation("MemorandumUpdater")
  deleted_memorandums        memorandums[]                 @relation("MemorandumDeleter")
  managed_memorandum_targets memorandum_target_divisions[] @relation("MemorandumTargetManager")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([deactivated_by])
  @@index([reactivated_by])
}

enum user_onboarding_statuses {
  NOT_ACTIVATED
  PENDING_ACTIVATION
  ACTIVE
}

enum auth_action_token_types {
  INVITE
  ACTIVATION
  SET_PASSWORD
  RESET_PASSWORD
}

enum digital_document_access_levels {
  NON_RESTRICT
  RESTRICT
}

enum mail_workflow_statuses {
  NEW
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum outgoing_mail_statuses {
  ACTIVE
  INACTIVE
}

enum outgoing_mail_delivery_media {
  EMAIL    @map("email")
  POS      @map("pos")
  KURIR    @map("kurir")
  LANGSUNG @map("langsung")
}

enum disposition_statuses {
  NEW
  IN_PROGRESS
  COMPLETED
  FORWARDED
}

enum digital_document_access_request_statuses {
  PENDING
  APPROVED
  REJECTED
}

enum digital_document_loan_statuses {
  PENDING
  APPROVED
  HANDED_OVER
  REJECTED
  BORROWED
  RETURNED
}

enum storage_activity_actions {
  CREATED
  UPDATED
  STORAGE_MOVED
  DELETED
  ACCESS_REQUESTED
  ACCESS_APPROVED
  ACCESS_REJECTED
  LOAN_REQUESTED
  LOAN_APPROVED
  LOAN_REJECTED
  LOAN_HANDED_OVER
  LOAN_RETURNED
}

enum watermark_statuses {
  PENDING
  PROCESSING
  APPLIED
  SKIPPED
  FAILED
  UNSUPPORTED
}

model auth_action_tokens {
  id         String                  @id @default(uuid())
  user_id    String
  type       auth_action_token_types
  token_hash String                  @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime                @default(now())

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, type])
  @@index([expires_at])
}

model refresh_tokens {
  id         String    @id @default(uuid())
  user_id    String
  token_hash String    @unique
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, revoked_at])
  @@index([expires_at])
}

model roles {
  id          String       @id @default(uuid())
  name        String       @unique
  users       users[]
  roles_menus role_menus[]
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
}

model divisions {
  id                      String                           @id @default(uuid())
  name                    String                           @unique
  users                   users[]
  incoming_mail_targets   incoming_mail_target_divisions[]
  memorandums             memorandums[]
  memorandum_targets      memorandum_target_divisions[]
  owned_digital_documents digital_documents[]              @relation("DigitalDocumentsOwnerDivision")
  created_at              DateTime                         @default(now())
  updated_at              DateTime                         @updatedAt
}

model menus {
  id                String       @id @default(uuid())
  name              String
  parent_id         String?
  parent_label      String?      @map("parent")
  children_snapshot String?      @map("children")
  icon              String?
  url               String       @default("")
  menu_type         String       @default("NAVIGATION")
  placement         String       @default("SIDEBAR")
  render_in_sidebar Boolean      @default(true)
  component_key     String?
  order             Int?
  roleMenus         role_menus[]
  parent            menus?       @relation("MenuHierarchy", fields: [parent_id], references: [id], onDelete: SetNull)
  children          menus[]      @relation("MenuHierarchy")
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt

  @@index([parent_id])
  @@index([order])
  @@index([menu_type])
  @@index([placement])
  @@index([render_in_sidebar])
}

model role_menus {
  id      String @id @default(uuid())
  role_id String
  menu_id String

  can_create Boolean  @default(false)
  can_read   Boolean  @default(false)
  can_update Boolean  @default(false)
  can_delete Boolean  @default(false)
  features   String[] @default([])

  role roles @relation(fields: [role_id], references: [id])
  menu menus @relation(fields: [menu_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([role_id, menu_id])
}

model notifications {
  id            String    @id @default(uuid())
  recipient_id  String
  module        String
  event_type    String
  entity_type   String
  entity_id     String
  title         String
  message       String
  link_url      String?
  priority      String    @default("NORMAL")
  read_at       DateTime?
  email_status  String    @default("SKIPPED")
  email_sent_at DateTime?
  email_error   String?
  dedupe_key    String?   @unique
  created_by    String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  recipient users  @relation("NotificationRecipient", fields: [recipient_id], references: [id], onDelete: Cascade)
  creator   users? @relation("NotificationCreator", fields: [created_by], references: [id], onDelete: SetNull)

  @@index([recipient_id, read_at, created_at])
  @@index([recipient_id, deleted_at])
  @@index([module, event_type])
  @@index([entity_type, entity_id])
  @@index([email_status])
}

model watermark_settings {
  id                  String   @id @default(uuid())
  is_enabled          Boolean  @default(false)
  target_modules      String[] @default(["digital_archive", "incoming_mail", "outgoing_mail", "memorandum"])
  watermark_type      String   @default("TEXT")
  text_template       String?
  text_color          String   @default("#1F2937")
  text_opacity        Float    @default(0.16)
  font_family         String   @default("Arial")
  font_size           Int      @default(42)
  image_path          String?
  image_original_name String?
  image_mime_type     String?
  image_size_bytes    Int?
  image_opacity       Float    @default(0.16)
  image_scale         Float    @default(0.35)
  position            String   @default("CENTER")
  repeat_pattern      Boolean  @default(true)
  rotation            Float    @default(-35)
  spacing_x           Int      @default(280)
  spacing_y           Int      @default(180)
  updated_by          String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([is_enabled])
}

model storage_usage_configs {
  id                         String   @id @default(uuid())
  free_quota_gb              Float    @default(100)
  overage_price_per_gb       Decimal  @default(200) @db.Decimal(12, 6)
  currency                   String   @default("IDR")
  billing_model              String   @default("TIERED")
  pricing_tiers              Json     @default("[]")
  manual_review_threshold_gb Float    @default(1000)
  is_active                  Boolean  @default(true)
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt

  @@index([is_active])
}

model storage_usage_daily_snapshots {
  id            String   @id @default(uuid())
  snapshot_date DateTime @unique @db.Date
  used_bytes    BigInt   @default(0)
  used_gb       Float    @default(0)
  file_count    Int      @default(0)
  breakdown     Json     @default("[]")
  source        String   @default("database_file_size")
  is_estimated  Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([snapshot_date])
  @@index([is_estimated])
}

model storage_offices {
  id         String             @id @default(uuid())
  code       String             @unique
  name       String
  cabinets   storage_cabinets[]
  created_at DateTime           @default(now())
  updated_at DateTime           @updatedAt
}

model storage_cabinets {
  id         String          @id @default(uuid())
  office_id  String
  code       String
  office     storage_offices @relation(fields: [office_id], references: [id])
  racks      storages[]
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt

  @@unique([office_id, code])
  @@index([office_id])
}

model storages {
  id         String   @id @default(uuid())
  cabinet_id String
  name       String
  capacity   Int?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  cabinet storage_cabinets @relation(fields: [cabinet_id], references: [id])

  digital_documents                   digital_documents[]
  incoming_mails                      incoming_mails[]
  outgoing_mails                      outgoing_mails[]
  memorandums                         memorandums[]
  digital_document_activity_logs_from digital_document_activity_logs[] @relation("DigitalDocumentActivityFromStorage")
  digital_document_activity_logs_to   digital_document_activity_logs[] @relation("DigitalDocumentActivityToStorage")

  @@unique([cabinet_id, name])
  @@index([cabinet_id])
}

model document_types {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String   @unique
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  digital_documents digital_documents[]
}

model letter_priorities {
  id             String           @id @default(uuid())
  name           String           @unique
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  incoming_mails incoming_mails[]
  outgoing_mails outgoing_mails[]
}

model incoming_mails {
  id                        String                 @id @default(uuid())
  letter_prioritie_id       String
  storage_id                String
  name                      String
  receive_date              DateTime
  address                   String
  mail_number               String                 @unique
  regarding                 String
  description               String?
  file                      String?
  file_name                 String?
  file_size_bytes           BigInt?
  watermark_status          watermark_statuses     @default(SKIPPED)
  watermark_file            String?
  watermark_file_size_bytes BigInt?
  watermark_source_path     String?
  watermark_settings_hash   String?
  watermark_error_message   String?
  watermark_requested_at    DateTime?
  watermark_applied_at      DateTime?
  status                    mail_workflow_statuses @default(NEW)
  created_by                String?
  updated_by                String?
  deleted_by                String?
  created_at                DateTime               @default(now())
  updated_at                DateTime               @updatedAt
  deleted_at                DateTime?
  letter_prioritie          letter_priorities      @relation(fields: [letter_prioritie_id], references: [id])
  storage                   storages               @relation(fields: [storage_id], references: [id])
  creator                   users?                 @relation("IncomingMailsCreator", fields: [created_by], references: [id])
  updater                   users?                 @relation("IncomingMailsUpdater", fields: [updated_by], references: [id])
  deleter                   users?                 @relation("IncomingMailsDeleter", fields: [deleted_by], references: [id])

  disposition_mails incoming_mail_dispositions[]
  target_divisions  incoming_mail_target_divisions[]

  @@index([letter_prioritie_id])
  @@index([storage_id])
  @@index([status])
  @@index([watermark_status])
}

model incoming_mail_target_divisions {
  id                String   @id @default(uuid())
  incoming_mails_id String
  division_id       String
  manager_id        String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  incoming_mail incoming_mails @relation(fields: [incoming_mails_id], references: [id], onDelete: Cascade)
  division      divisions      @relation(fields: [division_id], references: [id])
  manager       users?         @relation("IncomingMailTargetManager", fields: [manager_id], references: [id], onDelete: SetNull)

  @@unique([incoming_mails_id, division_id])
  @@index([division_id])
  @@index([manager_id])
}

model incoming_mail_dispositions {
  id                    String               @id @default(uuid())
  incoming_mails_id     String
  sender_id             String?
  receiver_id           String
  parent_disposition_id String?
  note                  String?
  start_date            DateTime?
  due_date              DateTime?
  status                disposition_statuses @default(NEW)
  is_complete           Boolean              @default(false)
  completed_at          DateTime?
  acted_at              DateTime?
  disposed_at           DateTime?            @default(now())
  created_at            DateTime             @default(now())
  updated_at            DateTime             @updatedAt

  incoming_mail      incoming_mails               @relation(fields: [incoming_mails_id], references: [id], onDelete: Cascade)
  sender             users?                       @relation("SenderDisposition", fields: [sender_id], references: [id])
  receiver           users                        @relation("ReceiverDisposition", fields: [receiver_id], references: [id])
  parent_disposition incoming_mail_dispositions?  @relation("IncomingMailDispositionChain", fields: [parent_disposition_id], references: [id], onDelete: SetNull)
  child_dispositions incoming_mail_dispositions[] @relation("IncomingMailDispositionChain")

  @@index([incoming_mails_id, status])
  @@index([parent_disposition_id])
}

model digital_documents {
  id                        String                         @id @default(uuid())
  storage_id                String
  owner_user_id             String?
  owner_division_id         String?
  debtor_id                 String?
  is_restricted             Boolean                        @default(false)
  access_level              digital_document_access_levels @default(NON_RESTRICT)
  document_type_id          String
  document_number           String                         @unique
  document_name             String
  description               String?
  file                      String?
  watermark_status          watermark_statuses             @default(SKIPPED)
  watermark_file            String?
  watermark_file_size_bytes BigInt?
  watermark_source_path     String?
  watermark_settings_hash   String?
  watermark_error_message   String?
  watermark_requested_at    DateTime?
  watermark_applied_at      DateTime?
  created_by                String
  updated_by                String?
  deleted_by                String?
  created_at                DateTime                       @default(now())
  updated_at                DateTime                       @updatedAt
  deleted_at                DateTime?

  storage       storages       @relation(fields: [storage_id], references: [id])
  document_type document_types @relation(fields: [document_type_id], references: [id])

  creator        users            @relation("DigitalDocumentsCreator", fields: [created_by], references: [id])
  owner          users?           @relation("DigitalDocumentsOwner", fields: [owner_user_id], references: [id], onDelete: SetNull)
  owner_division divisions?       @relation("DigitalDocumentsOwnerDivision", fields: [owner_division_id], references: [id], onDelete: SetNull)
  debtor         digital_debtors? @relation(fields: [debtor_id], references: [id], onDelete: SetNull)
  updater        users?           @relation("DigitalDocumentsUpdater", fields: [updated_by], references: [id])
  deleter        users?           @relation("DigitalDocumentsDeleter", fields: [deleted_by], references: [id])

  access_requests digital_document_access_requests[]
  loans           digital_document_loans[]
  document_files  document_files[]
  related_users   digital_document_related_users[]
  activity_logs   digital_document_activity_logs[]

  @@index([storage_id])
  @@index([owner_user_id])
  @@index([owner_division_id])
  @@index([debtor_id])
  @@index([document_type_id])
  @@index([created_by])
  @@index([access_level])
  @@index([watermark_status])
}

model digital_debtors {
  id                String    @id @default(uuid())
  debtor_number     String?   @unique
  name              String
  identity_number   String?   @unique
  financing_number  String?
  address           String?
  phone             String?
  branch_id         String?
  marketing_user_id String?
  customer_type     String?
  slik_segment      String?
  slik_status_code  String?
  slik_operation_code String?
  status            String    @default("ACTIVE")
  description       String?
  created_by        String?
  updated_by        String?
  deleted_by        String?
  deleted_at        DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  branch         branches?           @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  marketing_user users?              @relation("DebtorMarketingOwner", fields: [marketing_user_id], references: [id], onDelete: SetNull)
  documents      digital_documents[]

  individual_profile debtor_individual_profiles?
  legal_entity_profile debtor_legal_entity_profiles?
  contracts           debtor_contracts[]
  collaterals         debtor_collaterals[]
  contract_slik_snapshots debtor_contract_slik_snapshots[]
  debtor_documents    debtor_documents[]
  import_records      debtor_external_records[]
  slik_records        debtor_slik_records[]
  marketing_items     debtor_marketing_activities[]
  marketing_timelines debtor_marketing_timelines[]
  warning_letters     debtor_warning_letters[]
  ideb_uploads        debtor_ideb_uploads[]

  @@index([name])
  @@index([financing_number])
  @@index([branch_id])
  @@index([marketing_user_id])
  @@index([customer_type])
  @@index([slik_segment])
  @@index([slik_status_code])
  @@index([status])
  @@index([deleted_at])
}

model debtor_individual_profiles {
  id String @id @default(uuid())
  debtor_id String @unique
  identity_type_code String?
  name_as_identity String?
  full_name String?
  education_degree_code String?
  gender String?
  birth_place String?
  birth_date DateTime?
  tax_number String?
  address_detail String?
  village String?
  district String?
  city_code String?
  postal_code String?
  phone String?
  mobile_phone String?
  email String?
  domicile_country_code String?
  occupation_code String?
  workplace String?
  workplace_business_field_code String?
  workplace_address String?
  annual_gross_income Decimal? @db.Decimal(18, 2)
  income_source_code String?
  dependent_count Int?
  relationship_with_reporter_code String?
  debtor_group_code String?
  marital_status_code String?
  spouse_identity_number String?
  spouse_name String?
  spouse_birth_date DateTime?
  separate_assets_agreement String?
  violates_bmpk String?
  exceeds_bmpk String?
  mother_maiden_name String?
  branch_code String?
  operation_code String?
  status_code String?
  created_by String?
  updated_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  debtor digital_debtors @relation(fields: [debtor_id], references: [id], onDelete: Cascade)

  @@index([branch_code])
  @@index([status_code])
}

model debtor_legal_entity_profiles {
  id String @id @default(uuid())
  debtor_id String @unique
  business_identity_number String?
  business_name String?
  legal_form_code String?
  establishment_place String?
  establishment_deed_number String?
  establishment_deed_date DateTime?
  latest_amendment_deed_number String?
  latest_amendment_deed_date DateTime?
  phone String?
  mobile_phone String?
  email String?
  address_detail String?
  village String?
  district String?
  city_code String?
  postal_code String?
  domicile_country_code String?
  business_field_code String?
  relationship_with_reporter_code String?
  violates_bmpk String?
  exceeds_bmpk String?
  go_public String?
  debtor_group_code String?
  rating String?
  rating_agency String?
  rating_date DateTime?
  debtor_group_name String?
  branch_code String?
  operation_code String?
  status_code String?
  created_by String?
  updated_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  debtor digital_debtors @relation(fields: [debtor_id], references: [id], onDelete: Cascade)

  @@index([branch_code])
  @@index([status_code])
}

model digital_document_related_users {
  id          String   @id @default(uuid())
  document_id String
  user_id     String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  document digital_documents @relation(fields: [document_id], references: [id], onDelete: Cascade)
  user     users             @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([document_id, user_id])
  @@index([user_id])
}

model document_files {
  id          String    @id @default(uuid())
  document_id String
  file_path   String
  file_name   String?
  mime_type   String?
  size_bytes  BigInt?
  checksum    String?
  is_primary  Boolean   @default(false)
  uploaded_by String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  document digital_documents @relation(fields: [document_id], references: [id], onDelete: Cascade)
  uploader users?            @relation("DocumentFileUploader", fields: [uploaded_by], references: [id], onDelete: SetNull)

  @@unique([document_id, file_path])
  @@index([document_id, is_primary])
  @@index([uploaded_by])
}

model digital_document_access_requests {
  id             String                                   @id @default(uuid())
  document_id    String
  requester_id   String
  owner_id       String
  status         digital_document_access_request_statuses @default(PENDING)
  request_reason String
  action_note    String?
  expires_at     DateTime
  acted_by       String?
  acted_at       DateTime?
  approved_at    DateTime?
  rejected_at    DateTime?
  expired_at     DateTime?
  created_at     DateTime                                 @default(now())
  updated_at     DateTime                                 @updatedAt

  document  digital_documents @relation(fields: [document_id], references: [id], onDelete: Cascade)
  requester users             @relation("DigitalDocumentAccessRequester", fields: [requester_id], references: [id])
  owner     users             @relation("DigitalDocumentAccessOwner", fields: [owner_id], references: [id])
  actor     users?            @relation("DigitalDocumentAccessActor", fields: [acted_by], references: [id])

  @@index([document_id, status])
  @@index([requester_id, status])
  @@index([owner_id, status])
  @@index([status, expires_at])
}

model digital_document_loans {
  id                   String                         @id @default(uuid())
  document_id          String
  borrower_id          String
  status               digital_document_loan_statuses @default(PENDING)
  request_reason       String
  requested_start_date DateTime
  requested_due_date   DateTime
  approved_by          String?
  approved_at          DateTime?
  approval_note        String?
  rejected_by          String?
  rejected_at          DateTime?
  rejection_note       String?
  handed_over_by       String?
  handover_at          DateTime?
  handover_note        String?
  returned_by          String?
  returned_at          DateTime?
  return_note          String?
  created_at           DateTime                       @default(now())
  updated_at           DateTime                       @updatedAt

  document       digital_documents @relation(fields: [document_id], references: [id], onDelete: Cascade)
  borrower       users             @relation("DigitalDocumentLoanBorrower", fields: [borrower_id], references: [id])
  approver       users?            @relation("DigitalDocumentLoanApprover", fields: [approved_by], references: [id])
  rejector       users?            @relation("DigitalDocumentLoanRejector", fields: [rejected_by], references: [id])
  handover_actor users?            @relation("DigitalDocumentLoanHandOverActor", fields: [handed_over_by], references: [id])
  return_actor   users?            @relation("DigitalDocumentLoanReturnActor", fields: [returned_by], references: [id])

  @@index([document_id, status])
  @@index([borrower_id, status])
  @@index([status, requested_due_date])
}

model digital_document_activity_logs {
  id              String                   @id @default(uuid())
  document_id     String
  actor_id        String?
  action          storage_activity_actions
  from_storage_id String?
  to_storage_id   String?
  reference_type  String?
  reference_id    String?
  description     String?
  created_at      DateTime                 @default(now())

  document     digital_documents @relation(fields: [document_id], references: [id], onDelete: Cascade)
  actor        users?            @relation("DigitalDocumentActivityActor", fields: [actor_id], references: [id])
  from_storage storages?         @relation("DigitalDocumentActivityFromStorage", fields: [from_storage_id], references: [id])
  to_storage   storages?         @relation("DigitalDocumentActivityToStorage", fields: [to_storage_id], references: [id])

  @@index([document_id, created_at])
  @@index([action, created_at])
  @@index([from_storage_id])
  @@index([to_storage_id])
  @@map("storage_activity_logs")
}

model outgoing_mails {
  id String @id @default(uuid())

  letter_prioritie_id       String
  storage_id                String
  delivery_media            outgoing_mail_delivery_media
  name                      String
  send_date                 DateTime
  send_due_date             DateTime?
  response_due_date         DateTime?
  follow_up_note            String?
  address                   String
  mail_number               String                       @unique
  file                      String?
  file_name                 String?
  file_size_bytes           BigInt?
  watermark_status          watermark_statuses           @default(SKIPPED)
  watermark_file            String?
  watermark_file_size_bytes BigInt?
  watermark_source_path     String?
  watermark_settings_hash   String?
  watermark_error_message   String?
  watermark_requested_at    DateTime?
  watermark_applied_at      DateTime?
  status                    outgoing_mail_statuses       @default(ACTIVE)
  created_by                String?
  updated_by                String?
  deleted_by                String?
  created_at                DateTime                     @default(now())
  updated_at                DateTime                     @updatedAt
  deleted_at                DateTime?

  creator          users?            @relation("OutgoingMailsCreator", fields: [created_by], references: [id])
  updater          users?            @relation("OutgoingMailsUpdater", fields: [updated_by], references: [id])
  deleter          users?            @relation("OutgoingMailsDeleter", fields: [deleted_by], references: [id])
  letter_prioritie letter_priorities @relation(fields: [letter_prioritie_id], references: [id])
  storage          storages          @relation(fields: [storage_id], references: [id])

  @@index([letter_prioritie_id])
  @@index([storage_id])
  @@index([status])
  @@index([watermark_status])
  @@index([send_due_date])
  @@index([response_due_date])
}

model memorandums {
  id                        String                 @id @default(uuid())
  origin_division_id        String
  storage_id                String
  memo_number               String                 @unique
  memo_date                 DateTime
  received_date             DateTime
  regarding                 String
  description               String?
  file                      String?
  file_name                 String?
  file_size_bytes           BigInt?
  watermark_status          watermark_statuses     @default(SKIPPED)
  watermark_file            String?
  watermark_file_size_bytes BigInt?
  watermark_source_path     String?
  watermark_settings_hash   String?
  watermark_error_message   String?
  watermark_requested_at    DateTime?
  watermark_applied_at      DateTime?
  status                    mail_workflow_statuses @default(NEW)

  created_by String?
  updated_by String?
  deleted_by String?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  origin_division divisions @relation(fields: [origin_division_id], references: [id])
  storage         storages  @relation(fields: [storage_id], references: [id])

  creator users? @relation("MemorandumCreator", fields: [created_by], references: [id])
  updater users? @relation("MemorandumUpdater", fields: [updated_by], references: [id])
  deleter users? @relation("MemorandumDeleter", fields: [deleted_by], references: [id])

  dispositions     memorandum_dispositions[]
  target_divisions memorandum_target_divisions[]

  @@index([origin_division_id])
  @@index([storage_id])
  @@index([status])
  @@index([watermark_status])
}

model memorandum_target_divisions {
  id             String   @id @default(uuid())
  memorandums_id String
  division_id    String
  manager_id     String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  memorandum memorandums @relation(fields: [memorandums_id], references: [id], onDelete: Cascade)
  division   divisions   @relation(fields: [division_id], references: [id])
  manager    users?      @relation("MemorandumTargetManager", fields: [manager_id], references: [id], onDelete: SetNull)

  @@unique([memorandums_id, division_id])
  @@index([division_id])
  @@index([manager_id])
}

model memorandum_dispositions {
  id                    String               @id @default(uuid())
  memorandums_id        String
  sender_id             String?
  receiver_id           String
  parent_disposition_id String?
  note                  String?
  start_date            DateTime?
  due_date              DateTime?
  status                disposition_statuses @default(NEW)
  is_complete           Boolean              @default(false)
  completed_at          DateTime?
  acted_at              DateTime?
  disposed_at           DateTime?            @default(now())
  created_at            DateTime             @default(now())
  updated_at            DateTime             @updatedAt

  memorandum         memorandums               @relation(fields: [memorandums_id], references: [id], onDelete: Cascade)
  sender             users?                    @relation("SenderMemoDisposition", fields: [sender_id], references: [id])
  receiver           users                     @relation("ReceiverMemoDisposition", fields: [receiver_id], references: [id])
  parent_disposition memorandum_dispositions?  @relation("MemorandumDispositionChain", fields: [parent_disposition_id], references: [id], onDelete: SetNull)
  child_dispositions memorandum_dispositions[] @relation("MemorandumDispositionChain")

  @@index([memorandums_id, status])
  @@index([parent_disposition_id])
}

